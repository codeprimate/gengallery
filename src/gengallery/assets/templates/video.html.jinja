<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ video.title }} - {{ gallery.title }} - {{ site_name }}</title>
    <link href="/css/tailwind.css" rel="stylesheet">
    <link href="/css/site.css" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <meta name="robots" content="noindex, nofollow">
</head>
<body class="bg-gray-100">
    <header class="bg-white shadow-md">
        <div class="container mx-auto px-4 py-6">
            <h1 class="text-3xl font-bold text-gray-800">
                <a href="/">{{ site_name }}</a>
            </h1>
            <p class="text-gray-600">by {{ author }}</p>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8">
        <nav class="mb-4">
            <a href="/galleries/{{ gallery.id }}/index.html#{{ video.id }}" class="text-blue-500 hover:underline">&larr; Back to {{ gallery.title }}</a>
        </nav>

        <div class="bg-white rounded-lg shadow-md overflow-hidden relative">
            <div class="flex justify-center items-center">
                {% if nav_prev %}
                <a href="{{ nav_prev.url }}" class="absolute left-4 top-1/4 transform -translate-y-1/2 nav-arrow">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-white bg-black bg-opacity-50 rounded-full p-2">
                        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
                {% endif %}

                <div class="relative w-full max-w-5xl">
                    <video class="w-full max-h-[70vh] object-contain bg-black"
                           controls
                           playsinline
                           preload="none"
                           poster="{{ video.thumbnail_path }}">
                        <source src="{{ video.playback_path }}" type="video/mp4">
                    </video>
                </div>

                {% if nav_next %}
                <a href="{{ nav_next.url }}" class="absolute right-4 top-1/4 transform -translate-y-1/2 nav-arrow">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-white bg-black bg-opacity-50 rounded-full p-2">
                        <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
                {% endif %}
            </div>
            <div class="p-8">
                <h2 class="text-2xl font-bold mb-4">{{ video.title }}</h2>
                {% if video.caption %}
                <p class="text-gray-700 mb-4">{{ video.caption }}</p>
                {% endif %}
                {% if video.tags %}
                <div class="mb-4">
                    {% for tag in video.tags %}
                    <span class="inline-block bg-gray-200 rounded-full px-3 py-1 text-sm font-semibold text-gray-700 mr-2 mb-2">#{{ tag }}</span>
                    {% endfor %}
                </div>
                {% endif %}
                {% if video.exif %}
                <div class="grid grid-cols-2 gap-4">
                    {% for key, value in video.exif.items() %}
                    <div>
                        <span class="font-semibold">{{ key }}:</span> {{ value }}
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>
    </main>

    <footer class="bg-white shadow-md mt-12">
        <div class="container mx-auto px-4 py-6 text-center text-gray-600">
            &copy; {{ current_year }} {{ author }}. All rights reserved.
        </div>
    </footer>
    {% if gallery.requires_login %}
    <script src="/js/site.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            new GalleryLock('{{ gallery.id }}');
        });
    </script>
    {% endif %}
</body>
</html>
