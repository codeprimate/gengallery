<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Private Video - {{ site_name }}</title>
    <link href="/css/tailwind.css" rel="stylesheet">
    <link href="/css/site.css" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <meta name="robots" content="noindex, nofollow">
    <meta name="encrypted-gallery" content="true">
    <meta name="encrypted-manifest-url" content="{{ gallery.manifest_path }}">
</head>
<body class="bg-gray-100">
    <header class="bg-white shadow-md">
        <div class="container mx-auto px-4 py-6">
            <h1 class="text-3xl font-bold text-gray-800">
                <a href="/">{{ site_name }}</a>
            </h1>
            <p class="text-gray-600">by {{ author }}</p>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8">
        <nav class="mb-4">
            <a href="/galleries/{{ gallery.id }}/{{ protected_gallery_page }}#{{ video.id }}" class="text-blue-500 hover:underline">&larr; Back to {{ gallery.title }}</a>
        </nav>

        <div class="bg-white rounded-lg shadow-md overflow-hidden relative">
            <div class="flex justify-center items-center">
                {% if nav_prev %}
                <a href="{{ nav_prev.url }}" class="absolute left-4 top-1/4 transform -translate-y-1/2 nav-arrow">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-white bg-black bg-opacity-50 rounded-full p-2">
                        <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
                {% endif %}

                <div class="relative w-full max-w-5xl">
                    <video id="encryptedVideo"
                           class="w-full max-h-[70vh] object-contain bg-black"
                           controls
                           playsinline
                           preload="none"
                           data-encrypted-thumbnail-url="{{ video.thumbnail_path }}"
                           data-encrypted-playback-url="{{ video.playback_path }}"
                           data-encrypted-metadata-url="{{ video.metadata_path }}">
                    </video>
                    <div id="encryptedVideoOverlay" class="encrypted-overlay absolute inset-0 bg-gray-100 bg-opacity-75 flex items-center justify-center pointer-events-none">
                        <svg class="animate-spin h-8 w-8 text-gray-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </div>
                </div>

                {% if nav_next %}
                <a href="{{ nav_next.url }}" class="absolute right-4 top-1/4 transform -translate-y-1/2 nav-arrow">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-white bg-black bg-opacity-50 rounded-full p-2">
                        <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
                {% endif %}
            </div>
        </div>

        <section class="mt-6 bg-white rounded-lg shadow-md p-4" data-encrypted-metadata-url="{{ video.metadata_path }}">
            <p class="text-sm text-gray-600">
                Filename:
                <span class="encrypted-meta-field font-medium text-gray-800" data-field="filename" data-fallback=""></span>
            </p>
            <p class="text-sm text-gray-600 mt-1">
                Title:
                <span class="encrypted-meta-field font-medium text-gray-800" data-field="title" data-fallback="Encrypted video">Encrypted video</span>
            </p>
            <p class="text-sm text-gray-600 mt-1">
                Date:
                <span class="encrypted-meta-field font-medium text-gray-800" data-field="DateTimeOriginal" data-fallback=""></span>
            </p>
            <p class="text-sm text-gray-600 mt-1">
                Caption:
                <span class="encrypted-meta-field font-medium text-gray-800" data-field="caption" data-fallback=""></span>
            </p>
        </section>
    </main>

    <footer class="bg-white shadow-md mt-12">
        <div class="container mx-auto px-4 py-6 text-center text-gray-600">
            &copy; {{ current_year }} {{ author }}. All rights reserved.
        </div>
    </footer>

    <script src="/js/site.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            new EncryptedVideoPage('{{ gallery.id }}', {
                manifestUrl: '{{ gallery.manifest_path }}',
                videoSelector: '#encryptedVideo',
                overlaySelector: '#encryptedVideoOverlay',
            });
            new GalleryLock('{{ gallery.id }}');
        });
    </script>
</body>
</html>
